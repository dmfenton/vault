# Server Configuration
PORT=3000
WS_PORT=3001
NODE_ENV=development

# Vault Configuration
# Directory where the encrypted vault, master key and API token are stored.
VAULT_DATA_DIR=./vault-data

# Authentication
# Bearer token required for all sensitive HTTP endpoints AND for the phone's
# WebSocket connection (ws://host:3001/?token=<token>).
# If unset, the server generates one on first run and prints/persists it to
# <VAULT_DATA_DIR>/api-token.
VAULT_API_TOKEN=

# Optional: shared secret to enable HMAC signing/verification of WebSocket
# messages between the server and the phone. Leave empty to disable.
VAULT_WS_SHARED_SECRET=

# Phone Configuration
PHONE_ID=default-phone
SERVER_URL=http://localhost:3000

# Test/Debug routes (/test/*) — DANGEROUS: they bypass phone approval.
# Disabled unless this is "true" AND NODE_ENV is not "production".
ENABLE_TEST_ROUTES=false

# Logging
LOG_LEVEL=info
